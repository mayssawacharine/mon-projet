{% extends 'base.html.twig' %}

{% block title %}Accueil - Resto{% endblock %}

{% block body %}

    <!-- 1. BANNER SECTION -->
    <div class="container-fluid px-0 mb-4">
        <div class="position-relative bg-dark text-white overflow-hidden" style="height: 300px;">
            <img src="https://images.unsplash.com/photo-1555396273-367ea4eb4db5?q=80&w=1974" class="w-100 h-100 object-fit-cover opacity-50" alt="Banner">
            <div class="position-absolute top-50 start-0 translate-middle-y ms-5">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb text-white-50">
                        <li class="breadcrumb-item"><a href="#" class="text-white-50 text-decoration-none">Home</a></li>
                        <li class="breadcrumb-item active text-white" aria-current="page">Promotions du Moment</li>
                    </ol>
                </nav>
                <h1 class="display-4 fw-bold">Découvrez nos produits</h1>
                <p class="fs-5">{{ products|length }} produits disponibles</p>
            </div>
        </div>
    </div>

    <!-- 2. MAIN LAYOUT: SIDEBAR + PRODUCTS -->
    <div class="container-fluid px-4 mb-5">
        <div class="row">

            <!-- LEFT SIDEBAR (Filters) -->
            <div class="col-lg-3 d-none d-lg-block">
                <div class="card border-0 shadow-sm rounded-4 mb-4">
                    <div class="card-body">
                        <h5 class="fw-bold mb-3">Affiner</h5>
                        <hr>

                        <!-- Categories -->
                        <div class="mb-4">
                            <h6 class="fw-bold text-muted">Rayons</h6>
                            <div class="d-flex flex-column gap-2 mt-2">
                                <a href="{{ path('app_home') }}" class="text-decoration-none {{ currentCategory is empty ? 'fw-bold text-primary' : 'text-dark' }}">
                                    Tous les produits
                                </a>
                                <a href="{{ path('app_home', {'category': 'Food'}) }}" class="text-decoration-none {{ currentCategory == 'Food' ? 'fw-bold text-primary' : 'text-dark' }}">
                                    Nourriture
                                </a>
                                <a href="{{ path('app_home', {'category': 'Drinks'}) }}" class="text-decoration-none {{ currentCategory == 'Drinks' ? 'fw-bold text-primary' : 'text-dark' }}">
                                    Boissons
                                </a>
                            </div>
                        </div>

                        <!-- Price Filter -->
                        <div class="mb-4">
                            <h6 class="fw-bold text-muted">Prix</h6>
                            <form action="{{ path('app_home') }}" method="get">
                                <!-- Hidden Inputs to keep Search & Category alive -->
                                {% if currentCategory %}
                                    <input type="hidden" name="category" value="{{ currentCategory }}">
                                {% endif %}
                                {% if app.request.query.get('q') %}
                                    <input type="hidden" name="q" value="{{ app.request.query.get('q') }}">
                                {% endif %}
                                {# Preserve Sort as well #}
                                {% if app.request.query.get('sort') %}
                                    <input type="hidden" name="sort" value="{{ app.request.query.get('sort') }}">
                                {% endif %}

                                <div class="input-group mb-2">
                                    <span class="input-group-text bg-white">Max</span>
                                    <input type="number" name="price" class="form-control" placeholder="100" value="{{ app.request.query.get('price') }}">
                                    <span class="input-group-text bg-white">DT</span>
                                </div>
                                <button class="btn btn-sm btn-outline-primary w-100">Filtrer</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <!-- RIGHT CONTENT (Products) -->
            <div class="col-lg-9">

                <!-- ▼▼▼ UPDATED SORTING BAR ▼▼▼ -->
                <div class="d-flex justify-content-between align-items-center mb-4 p-3 bg-white rounded-3 shadow-sm border">
                    <span class="fw-bold text-muted">{{ products|length }} Résultats</span>

                    <div class="dropdown">
                        <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
                            Trier par :
                            {% if currentSort == 'price_asc' %}
                                Prix croissant
                            {% elseif currentSort == 'price_desc' %}
                                Prix décroissant
                            {% else %}
                                Pertinence
                            {% endif %}
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            {# Link 1: Pertinence (Remove sort param) #}
                            <li>
                                <a class="dropdown-item {% if not currentSort %}active{% endif %}"
                                   href="{{ path('app_home', app.request.query.all|merge({'sort': null})) }}">
                                    Pertinence
                                </a>
                            </li>
                            {# Link 2: Price Asc #}
                            <li>
                                <a class="dropdown-item {% if currentSort == 'price_asc' %}active{% endif %}"
                                   href="{{ path('app_home', app.request.query.all|merge({'sort': 'price_asc'})) }}">
                                    Prix croissant
                                </a>
                            </li>
                            {# Link 3: Price Desc #}
                            <li>
                                <a class="dropdown-item {% if currentSort == 'price_desc' %}active{% endif %}"
                                   href="{{ path('app_home', app.request.query.all|merge({'sort': 'price_desc'})) }}">
                                    Prix décroissant
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
                <!-- ▲▲▲ END SORTING BAR ▲▲▲ -->

                <!-- Product Grid -->
                <div class="row g-3">
                    {% for product in products %}
                        <div class="col-6 col-md-4 col-xl-3">
                            <!-- Product Card -->
                            <div class="card h-100 border-0 shadow-sm rounded-4 product-card position-relative">

                                <!-- Favorite Icon Logic -->
                                {% set isFav = app.session.get('favorites')[product.id] is defined %}
                                <a href="{{ path('favorite_toggle', {'id': product.id}) }}"
                                   class="btn btn-link position-absolute top-0 end-0 p-3 text-decoration-none"
                                   style="z-index: 10;">
                                    {% if isFav %}
                                        <i class="fas fa-heart text-danger fs-5"></i>
                                    {% else %}
                                        <i class="far fa-heart text-muted fs-5"></i>
                                    {% endif %}
                                </a>

                                <!-- Image -->
                                <div class="p-3 pb-0 text-center">
                                    {% if product.image %}
                                        <img src="{{ asset('uploads/produits/' ~ product.image) }}"
                                             class="img-fluid rounded-3"
                                             alt="{{ product.nom }}"
                                             style="height: 180px; object-fit: contain;">
                                    {% else %}
                                        <div class="bg-light rounded-3 d-flex align-items-center justify-content-center" style="height: 180px;">
                                            <i class="fas fa-camera fa-2x text-muted"></i>
                                        </div>
                                    {% endif %}
                                </div>

                                <!-- Body -->
                                <div class="card-body d-flex flex-column">
                                    <small class="text-danger fw-bold mb-1">
                                        {{ product.category.nom ?? 'Produit' }}
                                    </small>
                                    <h6 class="card-title fw-bold text-dark text-truncate mb-2">
                                        <a href="{{ path('product_show', {'id': product.id}) }}" class="text-decoration-none text-dark stretched-link">
                                            {{ product.nom }}
                                        </a>
                                    </h6>

                                    <div class="mt-auto d-flex align-items-end justify-content-between">
                                        <div>
                                            <span class="fs-5 fw-bold text-primary">{{ product.prix }} DT</span>
                                        </div>

                                        <!-- Add Button -->
                                        <a href="{{ path('cart_add', {'id': product.id}) }}" class="btn btn-primary btn-sm rounded-circle shadow-sm" style="width: 40px; height: 40px; display: grid; place-items: center; z-index: 2; position: relative;">
                                            <i class="fas fa-plus"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% else %}
                        <div class="col-12 text-center py-5">
                            <i class="fas fa-search fa-3x text-muted mb-3"></i>
                            <h4>Aucun produit trouvé</h4>
                            <p class="text-muted">Essayez de modifier votre recherche ou vos filtres.</p>
                            <a href="{{ path('app_home') }}" class="btn btn-primary">Voir tout</a>
                        </div>
                    {% endfor %}
                </div>

            </div>
        </div>
    </div>

    <style>
        .product-card { transition: transform 0.2s, box-shadow 0.2s; }
        .product-card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important; }
        .object-fit-cover { object-fit: cover; }
    </style>
{% endblock %}