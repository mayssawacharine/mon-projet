{% extends 'base.html.twig' %}

{% block title %}
    Dashboard -
    {% if client.prenom is defined %}
        {{ client.prenom }} {{ client.nom }}
    {% else %}
        Administrateur
    {% endif %}
{% endblock %}

{% block body %}
    <div class="container-fluid py-4">
        {# En-tête avec bienvenue et stats #}
        <div class="row mb-5">
            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <div class="row align-items-center">
                            <div class="col-md-8">
                                <h1 class="display-6 fw-bold mb-2">
                                    Bonjour
                                    {% if client.prenom is defined %}
                                        {{ client.prenom }}
                                    {% else %}
                                        Admin
                                    {% endif %}
                                    👋
                                </h1>
                                <p class="text-muted mb-0">Bienvenue sur votre espace personnel</p>
                            </div>
                            <div class="col-md-4 text-end">
                                <div class="btn-group">
                                    <a href="{{ path('app_reservation_new') }}" class="btn btn-primary">
                                        <i class="bi bi-plus-circle me-2"></i>Nouvelle réservation
                                    </a>
                                    <a href="{{ path('app_home') }}" class="btn btn-outline-primary">
                                        <i class="fas fa-store me-2"></i>Voir le menu
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Cartes de statistiques #}
        <div class="row mb-4">
            <div class="col-md-3 mb-3">
                <div class="card bg-primary text-white h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-subtitle mb-2 opacity-75">Commandes</h6>
                                <h2 class="card-title mb-0">{{ commandes|length }}</h2>
                            </div>
                            <i class="bi bi-cart fs-1 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card bg-success text-white h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-subtitle mb-2 opacity-75">Réservations</h6>
                                <h2 class="card-title mb-0">{{ reservations|length }}</h2>
                            </div>
                            <i class="bi bi-calendar-check fs-1 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card bg-info text-white h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-subtitle mb-2 opacity-75">Dépenses totales</h6>
                                <h2 class="card-title mb-0">
                                    {% set total = 0 %}
                                    {% for commande in commandes %}
                                        {% set total = total + commande.montantTotal %}
                                    {% endfor %}
                                    {{ total|number_format(2) }} $
                                </h2>
                            </div>
                            <i class="bi bi-currency-dollar fs-1 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card bg-warning text-dark h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-subtitle mb-2 opacity-75">Membre depuis</h6>
                                <h2 class="card-title mb-0">
                                    {# ▼ CORRECTED: Check if dateInscription exists ▼ #}
                                    {% if client.dateInscription is defined and client.dateInscription is not null %}
                                        {{ client.dateInscription|date('M Y') }}
                                    {% else %}
                                        -
                                    {% endif %}
                                </h2>
                            </div>
                            <i class="bi bi-person-circle fs-1 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Onglets améliorés #}
        <ul class="nav nav-pills mb-4" id="dashboardTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="infos-tab" data-bs-toggle="pill" data-bs-target="#infos">
                    <i class="bi bi-person me-2"></i>Mes infos
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="commandes-tab" data-bs-toggle="pill" data-bs-target="#commandes">
                    <i class="bi bi-cart me-2"></i>Mes commandes
                    {% if commandes|length > 0 %}
                        <span class="badge bg-primary rounded-pill ms-1">{{ commandes|length }}</span>
                    {% endif %}
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="reservations-tab" data-bs-toggle="pill" data-bs-target="#reservations">
                    <i class="bi bi-calendar me-2"></i>Mes réservations
                    {% if reservations|length > 0 %}
                        <span class="badge bg-success rounded-pill ms-1">{{ reservations|length }}</span>
                    {% endif %}
                </button>
            </li>
        </ul>

        <div class="tab-content" id="dashboardTabsContent">
            {# Onglet Infos - AMÉLIORÉ #}
            <div class="tab-pane fade show active" id="infos" role="tabpanel">
                <div class="row">
                    <div class="col-md-6">
                        <div class="card shadow-sm h-100">
                            <div class="card-header bg-white border-bottom">
                                <h5 class="card-title mb-0">
                                    <i class="bi bi-person-badge me-2"></i>Informations personnelles
                                </h5>
                            </div>
                            <div class="card-body">
                                <div class="list-group list-group-flush">
                                    <div class="list-group-item d-flex justify-content-between">
                                        <span class="fw-bold">Nom complet</span>
                                        <span>
                                            {% if client.prenom is defined %}
                                                {{ client.prenom }} {{ client.nom }}
                                            {% else %}
                                                Administrateur
                                            {% endif %}
                                        </span>
                                    </div>
                                    <div class="list-group-item d-flex justify-content-between">
                                        <span class="fw-bold">Email</span>
                                        <span>{{ client.email }}</span>
                                    </div>
                                    <div class="list-group-item d-flex justify-content-between">
                                        <span class="fw-bold">Téléphone</span>
                                        <span>
                                            {% if client.telephone is defined %}
                                                {{ client.telephone }}
                                            {% else %}
                                                Non renseigné
                                            {% endif %}
                                        </span>
                                    </div>
                                    <div class="list-group-item d-flex justify-content-between">
                                        <span class="fw-bold">Adresse</span>
                                        <span>
                                            {% if client.adresse is defined %}
                                                {{ client.adresse }}
                                            {% else %}
                                                Non renseignée
                                            {% endif %}
                                        </span>
                                    </div>
                                    <div class="list-group-item d-flex justify-content-between">
                                        <span class="fw-bold">Membre depuis</span>
                                        <span>
                                            {% if client.dateInscription is defined and client.dateInscription is not null %}
                                                {{ client.dateInscription|date('d/m/Y') }}
                                            {% else %}
                                                -
                                            {% endif %}
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 mt-3 mt-md-0">
                        <div class="card shadow-sm h-100">
                            <div class="card-header bg-white border-bottom">
                                <h5 class="card-title mb-0">
                                    <i class="bi bi-shield-check me-2"></i>Sécurité du compte
                                </h5>
                            </div>
                            <div class="card-body">
                                <div class="alert alert-info">
                                    <i class="bi bi-info-circle me-2"></i>
                                    Votre compte est sécurisé et actif.
                                </div>
                                <div class="d-grid gap-2">
                                    <a href="#" class="btn btn-outline-primary">
                                        <i class="bi bi-pencil me-2"></i>Modifier mes informations
                                    </a>
                                    <a href="#" class="btn btn-outline-secondary">
                                        <i class="bi bi-key me-2"></i>Changer mon mot de passe
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            {# Onglet Commandes - AMÉLIORÉ #}
            <div class="tab-pane fade" id="commandes" role="tabpanel">
                {% if commandes is not empty %}
                    <div class="row">
                        {% for commande in commandes %}
                            <div class="col-lg-6 mb-4">
                                <div class="card shadow-sm border-hover">
                                    <div class="card-header bg-white d-flex justify-content-between align-items-center">
                                        <h6 class="mb-0">Commande #{{ commande.id }}</h6>
                                        <span class="badge
                                        {% if commande.status == 'en_attente' %}bg-warning text-dark
                                        {% elseif commande.status == 'confirmee' %}bg-success
                                        {% elseif commande.status == 'livree' %}bg-info
                                        {% elseif commande.status == 'annulee' %}bg-danger
                                        {% else %}bg-secondary{% endif %}">
                                        {{ commande.status }}
                                    </span>
                                    </div>
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col-6">
                                                <small class="text-muted">Date</small>
                                                <p class="mb-1 fw-bold">{{ commande.dateCommande|date('d/m/Y H:i') }}</p>
                                            </div>
                                            <div class="col-6 text-end">
                                                <small class="text-muted">Total</small>
                                                <p class="mb-1 fw-bold text-primary">{{ commande.montantTotal }} $</p>
                                            </div>
                                        </div>
                                        <div class="mt-3">
                                            <small class="text-muted">Mode de paiement</small>
                                            <p class="mb-2">{{ commande.modePaiement }}</p>

                                            {% if commande.ligneCommandes|length > 0 %}
                                                <small class="text-muted">Articles</small>
                                                <ul class="list-group list-group-flush mt-2">
                                                    {% for ligne in commande.ligneCommandes|slice(0, 3) %}
                                                        <li class="list-group-item px-0">
                                                            {{ ligne.quantite }} × {{ ligne.produit.nom }}
                                                            <span class="float-end">{{ ligne.prixUnitaire }} $</span>
                                                        </li>
                                                    {% endfor %}
                                                    {% if commande.ligneCommandes|length > 3 %}
                                                        <li class="list-group-item px-0 text-center">
                                                            <small class="text-muted">+{{ commande.ligneCommandes|length - 3 }} autres articles</small>
                                                        </li>
                                                    {% endif %}
                                                </ul>
                                            {% endif %}
                                        </div>
                                    </div>
                                    <div class="card-footer bg-white">
                                        <div class="d-flex justify-content-between">
                                            <a href="#" class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-eye me-1"></i>Détails
                                            </a>
                                            {% if commande.status == 'en_attente' %}
                                                <a href="#" class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-x-circle me-1"></i>Annuler
                                                </a>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="text-center py-5">
                        <i class="bi bi-cart-x display-1 text-muted mb-3"></i>
                        <h4 class="text-muted">Aucune commande passée</h4>
                        <p class="text-muted mb-4">Vous n'avez pas encore passé de commande.</p>
                        <a href="{{ path('app_home') }}" class="btn btn-primary">
                            <i class="bi bi-shop me-2"></i>Découvrir notre menu
                        </a>
                    </div>
                {% endif %}
            </div>

            {# Onglet Réservations - AMÉLIORÉ #}
            <div class="tab-pane fade" id="reservations" role="tabpanel">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="mb-0">Mes réservations</h5>
                    <a href="{{ path('app_reservation_new') }}" class="btn btn-primary">
                        <i class="bi bi-plus-circle me-2"></i>Nouvelle réservation
                    </a>
                </div>

                {% if reservations is not empty %}
                    <div class="row">
                        {% for reservation in reservations %}
                            <div class="col-md-6 col-lg-4 mb-4">
                                <div class="card shadow-sm border-hover">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-start mb-3">
                                            <div>
                                                <h6 class="card-title mb-1">{{ reservation.dateReservation|date('d/m/Y') }}</h6>
                                                <p class="card-subtitle text-muted">
                                                    <i class="bi bi-clock me-1"></i>{{ reservation.dateReservation|date('H:i') }}
                                                </p>
                                            </div>
                                            <span class="badge
                                            {% if reservation.statut == 'confirmee' %}bg-success
                                            {% elseif reservation.statut == 'en_attente' %}bg-warning text-dark
                                            {% else %}bg-danger{% endif %}">
                                            {{ reservation.statut }}
                                        </span>
                                        </div>

                                        <div class="mb-3">
                                            <div class="d-flex align-items-center mb-2">
                                                <i class="bi bi-people me-2 text-primary"></i>
                                                <span class="fw-bold">{{ reservation.nbPersonnes }} personne(s)</span>
                                            </div>
                                            <div class="d-flex align-items-center">
                                                <i class="bi bi-calendar-event me-2 text-primary"></i>
                                                <small>Créée le {{ reservation.dateCreation|date('d/m/Y') }}</small>
                                            </div>
                                        </div>

                                        <div class="d-flex justify-content-between">
                                            {% if reservation.statut != 'annulee' %}
                                                <a href="{{ path('app_reservation_edit', {'id': reservation.id}) }}"
                                                   class="btn btn-sm btn-outline-primary">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <button class="btn btn-sm btn-outline-danger"
                                                        onclick="return confirm('Annuler cette réservation ?')">
                                                    <i class="bi bi-x-circle"></i>
                                                </button>
                                            {% else %}
                                                <span class="text-muted">Réservation annulée</span>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="text-center py-5">
                        <i class="bi bi-calendar-x display-1 text-muted mb-3"></i>
                        <h4 class="text-muted">Aucune réservation</h4>
                        <p class="text-muted mb-4">Vous n'avez pas encore de réservation.</p>
                        <a href="{{ path('app_reservation_new') }}" class="btn btn-primary">
                            <i class="bi bi-plus-circle me-2"></i>Faire ma première réservation
                        </a>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    <style>
        .border-hover {
            transition: all 0.3s ease;
            border: 1px solid #dee2e6;
        }
        .border-hover:hover {
            border-color: #0d6efd;
            box-shadow: 0 0.5rem 1rem rgba(0,0,0,.15);
            transform: translateY(-2px);
        }
        .nav-pills .nav-link {
            border-radius: 0.5rem;
            padding: 0.75rem 1.5rem;
            margin-right: 0.5rem;
        }
        .card {
            border-radius: 0.75rem;
        }
        .list-group-item {
            border: none;
            padding: 0.75rem 0;
        }
        .text-primary {
            color: #0d6efd !important;
        }
    </style>
{% endblock %}