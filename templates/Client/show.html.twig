{% extends 'base.html.twig' %}

{% block title %}{{ produit.nom }}{% endblock %}

{% block body %}
    <div class="container py-5">
        <div class="row align-items-center">
            <!-- Product Image -->
            <div class="col-md-6 mb-4 mb-md-0">
                {% if produit.image %}
                    <img src="{{ asset('uploads/produits/' ~ produit.image) }}"
                         alt="{{ produit.nom }}"
                         class="img-fluid rounded shadow-sm w-100"
                         style="max-height: 500px; object-fit: cover;">
                {% else %}
                    <div class="d-flex align-items-center justify-content-center bg-light rounded text-muted" style="height: 400px;">
                        <i class="fas fa-image fa-5x"></i>
                    </div>
                {% endif %}
            </div>

            <!-- Product Details -->
            <div class="col-md-6">
                <h1 class="display-4 fw-bold mb-3">{{ produit.nom }}</h1>

                <p class="h3 text-primary mb-4">{{ produit.prix }} DT</p>

                <div class="mb-4">
                    <span class="badge bg-secondary fs-6">{{ produit.category.nom }}</span>
                    {% if produit.disponible %}
                        <span class="badge bg-success fs-6 ms-2">Disponible</span>
                    {% else %}
                        <span class="badge bg-danger fs-6 ms-2">Indisponible</span>
                    {% endif %}
                </div>

                <p class="lead text-muted mb-5">
                    {{ produit.description }}
                </p>

                <div class="d-flex gap-3">
                    <!-- Add to Cart -->
                    <a href="{{ path('cart_add', {'id': produit.id}) }}" class="btn btn-primary btn-lg px-5">
                        <i class="fas fa-cart-plus me-2"></i> Ajouter
                    </a>

                    <!-- Back Button (CORRECTED) -->
                    <a href="{{ path('app_home') }}" class="btn btn-outline-secondary btn-lg">
                        Retour au menu
                    </a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}