{% extends 'base.html.twig' %}

{% block title %}Réservations - Admin{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1>Gestion des Réservations</h1>

    <div class="card mt-4">
        <div class="card-body">
            <table class="table">
                <thead>
                <tr>
                    <th>ID</th>
                    <th>Client</th>
                    <th>Date</th>
                    <th>Heure</th>
                    <th>Personnes</th>
                    <th>Statut</th>
                </tr>
                </thead>
                <tbody>
                {% for reservation in reservations %}
                <tr>
                    <td>{{ reservation.id }}</td>
                    <td>{{ reservation.client.nom ?? 'N/A' }}</td>
                    <td>{{ reservation.dateReservation|date('d/m/Y') }}</td>
                    <td>{{ reservation.heureReservation|date('H:i') }}</td>
                    <td>{{ reservation.nombrePersonnes ?? 1 }}</td>
                    <td>
                                <span class="badge bg-{{
                                    reservation.statut == 'confirmee' ? 'success' :
                                    reservation.statut == 'annulee' ? 'danger' : 'warning'
                                }}">
                                    {{ reservation.statut }}
                                </span>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="6" class="text-center">Aucune réservation</td>
                </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}