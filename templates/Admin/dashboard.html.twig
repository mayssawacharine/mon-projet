{% extends 'base.html.twig' %}

{% block title %}Dashboard Admin{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1>Dashboard Administrateur</h1>
        <p>Bienvenue {{ app.user.email }}</p>

        <!-- Navigation - 4 boutons principaux -->
        <div class="row mt-4">
            <div class="col-md-3 mb-3">
                <a href="{{ path('admin_commandes') }}" class="btn btn-success w-100">
                    <i class="fas fa-shopping-cart"></i> Commandes
                    {% if stats.commandes_aujourdhui is defined and stats.commandes_aujourdhui > 0 %}
                        <span class="badge bg-light text-dark ms-1">{{ stats.commandes_aujourdhui }}</span>
                    {% endif %}
                </a>
            </div>
            <div class="col-md-3 mb-3">
                <a href="{{ path('admin_reservations') }}" class="btn btn-info w-100">
                    <i class="fas fa-calendar-check"></i> Réservations
                    {% if stats.reservations_aujourdhui is defined and stats.reservations_aujourdhui > 0 %}
                        <span class="badge bg-light text-dark ms-1">{{ stats.reservations_aujourdhui }}</span>
                    {% endif %}
                </a>
            </div>
            <div class="col-md-3 mb-3">
                <a href="{{ path('admin_clients') }}" class="btn btn-warning w-100">
                    <i class="fas fa-users"></i> Clients
                </a>
            </div>
            <div class="col-md-3 mb-3">
                <a href="{{ path('admin_produits') }}" class="btn btn-primary w-100">
                    <i class="fas fa-utensils"></i> Produits
                </a>
            </div>
        </div>

        <!-- Statistiques -->
        <div class="row mt-4">
            <div class="col-md-4">
                <div class="card bg-success text-white">
                    <div class="card-body">
                        <h5>Commandes</h5>
                        <h2>{{ stats.commandes_aujourdhui ?? 15 }}</h2>
                        <small class="opacity-75">Total</small>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-info text-white">
                    <div class="card-body">
                        <h5>Réservations</h5>
                        <h2>{{ stats.reservations_aujourdhui ?? 8 }}</h2>
                        <small class="opacity-75">Total</small>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-primary text-white">
                    <div class="card-body">
                        <h5>Chiffre d'affaires</h5>
                        <h2>{{ stats.chiffre_affaires ?? 1250 }} €</h2>
                        <small class="opacity-75">Total</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tableaux récents -->
        <div class="row mt-4">
            <!-- Commandes récentes -->
            {% if recentOrders is defined and recentOrders|length > 0 %}
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                            <h5 class="mb-0"><i class="fas fa-shopping-cart"></i> Commandes Récentes</h5>
                            <a href="{{ path('admin_commandes') }}" class="btn btn-sm btn-light">
                                Voir tout
                            </a>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-sm table-hover mb-0">
                                    <thead class="table-light">
                                    <tr>
                                        <th>ID</th>
                                        <th>Client</th>
                                        <th>Date</th>
                                        <th>Montant</th>
                                        <th>Statut</th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    {% for commande in recentOrders|slice(0, 5) %}
                                        <tr>
                                            <td><strong>#{{ commande.id }}</strong></td>
                                            <td>{{ commande.client.nom ?? 'N/A' }}</td>
                                            <td>{{ commande.dateCommande|date('d/m/Y H:i') }}</td>
                                            <td>{{ commande.montantTotal }} €</td>
                                            <td>
                                            <span class="badge bg-{{
                                            commande.status == 'terminee' ? 'success' :
                                            commande.status == 'annulee' ? 'danger' : 'warning'
                                            }}">
                                                {{ commande.status|replace({'_': ' '})|title }}
                                            </span>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            {% endif %}

            <!-- Réservations récentes -->
            {% if recentReservations is defined and recentReservations|length > 0 %}
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                            <h5 class="mb-0"><i class="fas fa-calendar-check"></i> Réservations Récentes</h5>
                            <a href="{{ path('admin_reservations') }}" class="btn btn-sm btn-light">
                                Voir tout
                            </a>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-sm table-hover mb-0">
                                    <thead class="table-light">
                                    <tr>
                                        <th>ID</th>
                                        <th>Client</th>
                                        <th>Date</th>
                                        <th>Personnes</th>
                                        <th>Statut</th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    {% for reservation in recentReservations|slice(0, 5) %}
                                        <tr>
                                            <td><strong>#{{ reservation.id }}</strong></td>
                                            <td>{{ reservation.client.nom ?? 'N/A' }}</td>
                                            <td>{{ reservation.dateReservation|date('d/m/Y H:i') }}</td>
                                            <td>{{ reservation.nbPersonnes }}</td>
                                            <td>
                                            <span class="badge bg-{{
                                            reservation.statut == 'confirmee' ? 'success' :
                                            reservation.statut == 'annulee' ? 'danger' : 'warning'
                                            }}">
                                                {{ reservation.statut|title }}
                                            </span>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>

    </div>
{% endblock %}