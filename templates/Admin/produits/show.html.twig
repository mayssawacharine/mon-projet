{% extends 'base.html.twig' %}

{% block title %}Détails Produit #{{ produit.id }} - Admin{% endblock %}

{% block body %}
    <div class="container mt-5">
        <div class="row">
            <div class="col-md-8 offset-md-2">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h1>📦 Détails du Produit</h1>
                    <a href="{{ path('admin_produits') }}" class="btn btn-secondary">
                        ← Retour à la liste
                    </a>
                </div>

                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Produit #{{ produit.id }} - {{ produit.nom }}</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <h6>Informations principales</h6>
                                <p><strong>Nom :</strong> {{ produit.nom }}</p>
                                <p><strong>Prix :</strong> {{ produit.prix }} €</p>
                                <p><strong>Catégorie :</strong>
                                    {% if produit.category %}
                                        {{ produit.category.nom }}
                                    {% else %}
                                        <span class="text-muted">Non catégorisé</span>
                                    {% endif %}
                                </p>
                                <p><strong>Disponible :</strong>
                                    {% if produit.disponible %}
                                        <span class="badge bg-success">Oui</span>
                                    {% else %}
                                        <span class="badge bg-danger">Non</span>
                                    {% endif %}
                                </p>
                            </div>
                            <div class="col-md-6">
                                <h6>Image</h6>
                                {% if produit.image %}
                                    <img src="{{ asset('uploads/produits/' ~ produit.image) }}"
                                         alt="{{ produit.nom }}"
                                         class="img-fluid rounded"
                                         style="max-height: 200px;">
                                {% else %}
                                    <p class="text-muted">Aucune image</p>
                                {% endif %}
                            </div>
                        </div>

                        <div class="row mt-3">
                            <div class="col-12">
                                <h6>Description</h6>
                                <p>{{ produit.description ?? 'Aucune description' }}</p>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer">
                        <div class="btn-group">
                            <a href="{{ path('admin_produit_edit', {'id': produit.id}) }}"
                               class="btn btn-warning">
                                ✏️ Éditer
                            </a>
                            <a href="{{ path('admin_produits') }}"
                               class="btn btn-secondary">
                                Retour à la liste
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}