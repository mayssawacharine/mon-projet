{% extends 'base.html.twig' %}

{% block title %}Éditer Produit #{{ produit.id }} - Admin{% endblock %}

{% block body %}
    <div class="container mt-5">
        <div class="row">
            <div class="col-md-8 offset-md-2">
                <h1 class="mb-4">✏️ Éditer Produit #{{ produit.id }}</h1>

                <a href="{{ path('admin_produits') }}" class="btn btn-secondary mb-4">
                    ← Retour à la liste
                </a>

                {{ form_start(form) }}
                <div class="card">
                    <div class="card-header bg-warning text-white">
                        <h5 class="mb-0">Modification du produit</h5>
                    </div>
                    <div class="card-body">
                        {{ form_widget(form) }}
                    </div>
                    <div class="card-footer">
                        <div class="btn-group">
                            <button type="submit" class="btn btn-primary">
                                💾 Enregistrer
                            </button>
                            <a href="{{ path('admin_produits') }}" class="btn btn-secondary">
                                Annuler
                            </a>
                            <a href="{{ path('admin_produit_show', {'id': produit.id}) }}"
                               class="btn btn-info">
                                Voir les détails
                            </a>
                        </div>
                    </div>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}