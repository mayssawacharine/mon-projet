{% extends 'base.html.twig' %}

{% block title %}Nouveau Client - Admin{% endblock %}

{% block body %}
    <div class="container mt-5">
        <div class="row">
            <div class="col-md-8 offset-md-2">
                <h1 class="mb-4">➕ Nouveau Client</h1>

                {{ form_start(form) }}
                <div class="card">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">Création d'un nouveau client</h5>
                    </div>
                    <div class="card-body">
                        {{ form_widget(form) }}
                    </div>
                    <div class="card-footer">
                        <div class="btn-group">
                            <button type="submit" class="btn btn-primary">
                                💾 Créer le client
                            </button>
                            <a href="{{ path('admin_clients') }}" class="btn btn-secondary">
                                Annuler
                            </a>
                        </div>
                    </div>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}