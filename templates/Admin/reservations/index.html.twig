{% extends 'base.html.twig' %}

{% block title %}Réservations - Admin{% endblock %}

{% block body %}
    <div class="container-fluid mt-4">
        <h1 class="mb-4">Gestion des Réservations</h1>

        <!-- Filtres -->
        <div class="card mb-4">
            <div class="card-body">
                <form method="get" class="row g-3">
                    <div class="col-md-4">
                        <input type="date" name="date" class="form-control"
                               value="{{ currentDate }}">
                    </div>
                    <div class="col-md-4">
                        <select name="statut" class="form-select">
                            <option value="">Tous les statuts</option>
                            <option value="en_attente" {{ app.request.query.get('statut') == 'en_attente' ? 'selected' : '' }}>En attente</option>
                            <option value="confirmee" {{ app.request.query.get('statut') == 'confirmee' ? 'selected' : '' }}>Confirmée</option>
                            <option value="annulee" {{ app.request.query.get('statut') == 'annulee' ? 'selected' : '' }}>Annulée</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <button type="submit" class="btn btn-primary w-100">Filtrer</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Liste des réservations -->
        <div class="card">
            <div class="card-body">
                {% if reservations is not empty %}
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                            <tr>
                                <th>ID</th>
                                <th>Client</th>
                                <th>Date & Heure</th>
                                <th>Personnes</th>
                                <th>Statut</th>
                                <th>Actions</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for reservation in reservations %}
                                <tr>
                                    <td>#{{ reservation.id }}</td>
                                    <td>
                                        {{ reservation.client.nom ?? '' }} {{ reservation.client.prenom ?? '' }}
                                        <br>
                                        <small class="text-muted">{{ reservation.client.email ?? '' }}</small>
                                    </td>
                                    <td>
                                        {{ reservation.dateReservation|date('d/m/Y') }}
                                        <br>
                                        <!-- CORRECTION: heureReservation -> dateReservation -->
                                        <small>{{ reservation.dateReservation|date('H:i') }}</small>
                                    </td>
                                    <!-- CORRECTION: nombrePersonnes -> nbPersonnes -->
                                    <td>{{ reservation.nbPersonnes }}</td>
                                    <td>
                                        <span class="badge bg-{{
                                        reservation.statut == 'confirmee' ? 'success' :
                                        reservation.statut == 'annulee' ? 'danger' :
                                        'warning'
                                        }}">
                                            {{ reservation.statut|title }}
                                        </span>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-info">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                        <button class="btn btn-sm btn-warning">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <div class="alert alert-info">
                        Aucune réservation trouvée pour les critères sélectionnés.
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}