{% extends 'base.html.twig' %}

{% block title %}Mon Panier{% endblock %}

{% block body %}
    <div class="container py-5">
        <h2 class="mb-4 text-center fw-bold">🛒 Mon Panier</h2>

        {% if items is empty %}
            <div class="alert alert-warning text-center p-5 rounded-4 shadow-sm">
                <h4>Votre panier est vide.</h4>
                <p class="mb-4">Il semble que vous n'avez rien commandé pour le moment.</p>
                <!-- FIXED ROUTE: path('app_home') -->
                <a href="{{ path('app_home') }}" class="btn btn-primary rounded-pill px-4">
                    Retour au menu
                </a>
            </div>
        {% else %}
            <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                <div class="table-responsive">
                    <table class="table table-hover text-center align-middle mb-0">
                        <thead class="bg-light text-secondary">
                        <tr>
                            <th class="py-3">#</th>
                            <th class="py-3 text-start ps-4">Produit</th>
                            <th class="py-3">Prix Unitaire</th>
                            <th class="py-3">Quantité</th>
                            <th class="py-3">Sous-total</th>
                            <th class="py-3">Actions</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for item in items %}
                            <tr>
                                <td class="text-muted">{{ loop.index }}</td>
                                <td class="text-start ps-4">
                                    <div class="d-flex align-items-center">
                                        <!-- Optional: Add Image if available -->
                                        {% if item.produit.image %}
                                            <img src="{{ asset('uploads/produits/' ~ item.produit.image) }}"
                                                 style="width: 40px; height: 40px; object-fit: cover; border-radius: 6px;"
                                                 class="me-2">
                                        {% endif %}
                                        <strong>{{ item.produit.nom }}</strong>
                                    </div>
                                </td>
                                <td>{{ item.produit.prix }} DT</td>
                                <td>
                                    <div class="d-flex justify-content-center align-items-center">
                                        <a href="{{ path('cart_decrease', {'id': item.produit.id}) }}" class="btn btn-outline-secondary btn-sm rounded-circle" style="width: 30px; height: 30px; padding: 0; line-height: 28px;">-</a>
                                        <span class="mx-3 fw-bold">{{ item.quantity }}</span>
                                        <a href="{{ path('cart_increase', {'id': item.produit.id}) }}" class="btn btn-outline-secondary btn-sm rounded-circle" style="width: 30px; height: 30px; padding: 0; line-height: 28px;">+</a>
                                    </div>
                                </td>
                                <td class="fw-bold text-primary">{{ item.produit.prix * item.quantity }} DT</td>
                                <td>
                                    <!-- FontAwesome Icons used here -->
                                    <a href="{{ path('cart_remove', {'id': item.produit.id}) }}"
                                       class="btn btn-danger btn-sm rounded-pill px-3"
                                       onclick="return confirm('Supprimer ce produit ?')">
                                        <i class="fas fa-trash"></i> Supprimer
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="row mt-4">
                <div class="col-md-6 offset-md-6">
                    <div class="card border-0 shadow-sm bg-light rounded-4">
                        <div class="card-body p-4 d-flex justify-content-between align-items-center">
                            <span class="fs-5 text-muted">Total à payer:</span>
                            <strong class="fs-3 text-primary">{{ total }} DT</strong>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-5">
                <!-- FIXED ROUTE: path('app_home') -->
                <a href="{{ path('app_home') }}" class="btn btn-outline-secondary rounded-pill px-4">
                    <i class="fas fa-arrow-left me-2"></i> Continuer mes achats
                </a>

                <a href="{{ path('cart_checkout') }}" class="btn btn-success btn-lg rounded-pill px-5 shadow"
                   onclick="return confirm('Confirmer la commande ?')">
                    <i class="fas fa-check-circle me-2"></i> Passer la commande
                </a>
            </div>

            <div class="alert alert-info mt-5 rounded-3 border-0 bg-light text-secondary">
                <i class="fas fa-info-circle me-2"></i>
                <strong>Information :</strong> Après confirmation, votre commande sera visible dans votre dashboard.
            </div>
        {% endif %}
    </div>
{% endblock %}